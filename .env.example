# Copy to .env.local and adjust.

# true (default) = UI runs with simulated data, no live SDK/wallet.
# false = use the real STON.fi + Omniston integrations.
VITE_MOCK=true

# Network: mainnet | testnet. (testnet is only for testing TON Connect/signing;
# yield/Omniston needs mainnet because api.ston.fi & liquidity are mainnet-only)
VITE_NETWORK=mainnet

# TON RPC endpoint + API key (toncenter / tonapi)
VITE_TON_RPC=https://toncenter.com/api/v2/jsonRPC
VITE_TON_API_KEY=

# Public TON Connect manifest URL (HTTPS, via a tunnel during dev)
# VITE_MANIFEST_URL=https://<subdomain>.ngrok.app/tonconnect-manifest.json

# (optional) override the stable pool address instead of resolving via the API
# VITE_SAVINGS_POOL=
