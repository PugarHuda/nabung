# Salin ke .env.local lalu sesuaikan.

# true (default) = UI jalan dengan data simulasi, tanpa SDK/wallet live.
# false = pakai integrasi STON.fi + Omniston sungguhan.
VITE_MOCK=true

# Jaringan: mainnet | testnet. (testnet hanya untuk uji TON Connect/tanda tangan;
# yield/Omniston butuh mainnet karena api.ston.fi & likuiditas = mainnet)
VITE_NETWORK=mainnet

# Endpoint TON RPC + API key (toncenter / tonapi)
VITE_TON_RPC=https://toncenter.com/api/v2/jsonRPC
VITE_TON_API_KEY=

# URL publik manifest TON Connect (HTTPS, lewat tunnel saat dev)
# VITE_MANIFEST_URL=https://<subdomain>.ngrok.app/tonconnect-manifest.json

# (opsional) override alamat stable pool kalau tidak mau resolve via API
# VITE_SAVINGS_POOL=
